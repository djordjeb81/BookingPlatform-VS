<Window x:Class="SmartBooking_Desk.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Podešavanja"
        Height="820"
        Width="1400"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                Background="#F5F5F5"
                BorderBrush="#DADADA"
                BorderThickness="1"
                CornerRadius="6">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="Podešavanja"
                               FontSize="22"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,4,0,0"
                               Text="Ovde podešavate podatke potrebne za rad aplikacije."
                               Foreground="#555555"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#FAFAFA"
                    BorderBrush="#DDDDDD"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8">
                <StackPanel>
                    <TextBlock Text="Sekcije"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <ListBox x:Name="SectionsListBox"
                             SelectionChanged="SectionsListBox_SelectionChanged">
                        <ListBoxItem IsSelected="True" Tag="Services">Usluge</ListBoxItem>
                        <ListBoxItem Tag="Staff">Radnici</ListBoxItem>
                        <ListBoxItem Tag="Resources">Resursi</ListBoxItem>
                        <ListBoxItem Tag="WorkingHours">Radno vreme</ListBoxItem>
                        <ListBoxItem Tag="Business">Podaci o biznisu</ListBoxItem>
                    </ListBox>

                    <Border Margin="0,12,0,0"
                            Padding="10"
                            Background="#F7F7F7"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="6">
                        <TextBlock TextWrapping="Wrap"
                                   Foreground="#555555">
                            TODO: Kasnije ovde dodati i licence, korisnike i napredna podešavanja.
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <Grid Grid.Column="2">
                <Grid x:Name="ServicesSection">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="320"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Usluge" Padding="8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="8"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <DockPanel Grid.Row="0" LastChildFill="False">
                                    <Button x:Name="RefreshServicesButton"
                                            Content="Osveži"
                                            Width="100"
                                            Height="32"
                                            Margin="0,0,8,0"
                                            Click="RefreshServicesButton_Click"/>
                                    <Button x:Name="NewServiceButton"
                                            Content="Nova usluga"
                                            Width="120"
                                            Height="32"
                                            Click="NewServiceButton_Click"/>
                                </DockPanel>

                                <DataGrid Grid.Row="2"
                                          x:Name="ServicesGrid"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          SelectionMode="Single"
                                          SelectionChanged="ServicesGrid_SelectionChanged">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Naziv" Width="220" Binding="{Binding Name}" />
                                        <DataGridTextColumn Header="Trajanje" Width="110" Binding="{Binding EstimatedDurationMin}" />
                                        <DataGridTextColumn Header="Cena" Width="120" Binding="{Binding BasePrice}" />
                                        <DataGridCheckBoxColumn Header="Aktivna" Width="90" Binding="{Binding IsActive}" />
                                        <DataGridTextColumn Header="Opis" Width="*" Binding="{Binding Description}" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Detalji usluge" Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="Naziv usluge"/>
                                    <TextBox x:Name="ServiceNameTextBox" Height="34" Margin="0,6,0,12"/>

                                    <TextBlock Text="Opis"/>
                                    <TextBox x:Name="ServiceDescriptionTextBox"
                                             Height="80"
                                             Margin="0,6,0,12"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"/>

                                    <TextBlock Text="Cena"/>
                                    <TextBox x:Name="ServicePriceTextBox" Height="34" Margin="0,6,0,12"/>

                                    <TextBlock Text="Trajanje (min)"/>
                                    <TextBox x:Name="ServiceDurationTextBox" Height="34" Margin="0,6,0,12" Text="30"/>

                                    <CheckBox x:Name="ServiceIsActiveCheckBox"
                                              Content="Usluga je aktivna"
                                              Margin="0,0,0,12"
                                              IsChecked="True"/>



                                    <WrapPanel Margin="0,0,0,12">
                                        <Button x:Name="SaveNewServiceButton"
            Content="Sačuvaj novu"
            Width="130"
            Height="36"
            Margin="0,0,8,8"
            Click="SaveNewServiceButton_Click"/>
                                        <Button x:Name="SaveServiceChangesButton"
            Content="Sačuvaj izmene"
            Width="130"
            Height="36"
            Margin="0,0,8,8"
            Click="SaveServiceChangesButton_Click"/>
                                        <Button x:Name="ActivateServiceButton"
            Content="Aktiviraj"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="ActivateServiceButton_Click"/>
                                        <Button x:Name="DeactivateServiceButton"
            Content="Deaktiviraj"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="DeactivateServiceButton_Click"/>
                                        <Button x:Name="DeleteServiceButton"
            Content="Obriši"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="DeleteServiceButton_Click"/>
                                    </WrapPanel>

                                    <Border Padding="10"
                                            Background="#F7F7F7"
                                            BorderBrush="#DDDDDD"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <TextBlock TextWrapping="Wrap"
                                                   Foreground="#555555">
                                            Donji deo služi za grafičko uređivanje zauzeća resursa po minutima.
                                        </TextBlock>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </GroupBox>
                    </Grid>

                    <GroupBox Grid.Row="2" Header="Raspored radnika i resursa po minutima" Padding="10" MaxHeight="420">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <Button x:Name="AddTimelineRowButton"
                                        Content="Dodaj stavku"
                                        Width="110"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="AddTimelineRowButton_Click"/>
                                <Button x:Name="RemoveTimelineRowButton"
                                        Content="Obriši red"
                                        Width="110"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="RemoveTimelineRowButton_Click"/>
                                <Button x:Name="SaveTimelineButton"
                                        Content="Sačuvaj raspored"
                                        Width="150"
                                        Height="32"
                                        Click="SaveTimelineButton_Click"/>
                            </DockPanel>

                            <ScrollViewer x:Name="TimelineScrollViewer"
                                          Grid.Row="2"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Auto"
                                          CanContentScroll="True"
                                          PreviewMouseWheel="TimelineScrollViewer_PreviewMouseWheel">
                                <StackPanel>
                                    <Grid x:Name="TimelineHeaderGrid"
                                          Margin="0,0,0,6"/>
                                    <StackPanel x:Name="TimelineRowsPanel"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </GroupBox>
                </Grid>

                <Grid x:Name="StaffSection" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Radnici" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <Button x:Name="RefreshStaffButton"
                                        Content="Osveži"
                                        Width="100"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="RefreshStaffButton_Click"/>
                                <Button x:Name="NewStaffButton"
                                        Content="Novi radnik"
                                        Width="120"
                                        Height="32"
                                        Click="NewStaffButton_Click"/>
                            </DockPanel>

                            <DataGrid Grid.Row="2"
                                      x:Name="StaffGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="StaffGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Ime" Width="220" Binding="{Binding DisplayName}" />
                                    <DataGridTextColumn Header="Uloga" Width="180" Binding="{Binding Title}" />
                                    <DataGridCheckBoxColumn Header="Prima termine" Width="110" Binding="{Binding IsBookable}" />
                                    <DataGridCheckBoxColumn Header="Aktivan" Width="90" Binding="{Binding IsActive}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>


                    <GroupBox Grid.Column="2" Header="Detalji radnika" Padding="10">
                        <TabControl Margin="0">
                            <TabItem Header="Detalji radnika">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="8">
                                        <TextBlock Text="Ime i prikaz"/>
                                        <TextBox x:Name="StaffDisplayNameTextBox"
                             Height="34"
                             Margin="0,6,0,12"/>

                                        <TextBlock Text="Uloga / zvanje"/>
                                        <TextBox x:Name="StaffTitleTextBox"
                             Height="34"
                             Margin="0,6,0,12"/>

                                        <CheckBox x:Name="StaffIsBookableCheckBox"
                              Content="Prima termine"
                              Margin="0,0,0,12"
                              IsChecked="True"/>

                                        <CheckBox x:Name="StaffIsActiveCheckBox"
                              Content="Radnik je aktivan"
                              Margin="0,0,0,16"
                              IsChecked="True"/>

                                        <WrapPanel Margin="0,0,0,12">
                                            <Button x:Name="SaveNewStaffButton"
            Content="Sačuvaj novog"
            Width="130"
            Height="36"
            Margin="0,0,8,8"
            Click="SaveNewStaffButton_Click"/>
                                            <Button x:Name="SaveStaffChangesButton"
            Content="Sačuvaj izmene"
            Width="130"
            Height="36"
            Margin="0,0,8,8"
            Click="SaveStaffChangesButton_Click"/>
                                            <Button x:Name="ActivateStaffButton"
            Content="Aktiviraj"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="ActivateStaffButton_Click"/>
                                            <Button x:Name="DeactivateStaffButton"
            Content="Deaktiviraj"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="DeactivateStaffButton_Click"/>
                                            <Button x:Name="DeleteStaffButton"
            Content="Obriši"
            Width="110"
            Height="36"
            Margin="0,0,8,8"
            Click="DeleteStaffButton_Click"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Usluge i resursi">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="8">
                                        <GroupBox Header="Usluge koje radnik radi"
                              Margin="0,0,0,12"
                              Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <ListBox x:Name="StaffServicesListBox"
                                     Grid.Row="0"
                                     BorderThickness="1"
                                     MinHeight="180"
                                     MaxHeight="260"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                                  Margin="2"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <WrapPanel Grid.Row="2">
                                                    <Button x:Name="SaveStaffServicesButton"
                                        Content="Sačuvaj usluge"
                                        Width="140"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="SaveStaffServicesButton_Click"/>
                                                </WrapPanel>
                                            </Grid>
                                        </GroupBox>

                                        <GroupBox Header="Resursi koje radnik koristi"
                              Margin="0,0,0,12"
                              Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="8"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <ListBox x:Name="StaffResourcesListBox"
                                     Grid.Row="0"
                                     BorderThickness="1"
                                     MinHeight="180"
                                     MaxHeight="260"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <CheckBox Content="{Binding Name}"
                                                  IsChecked="{Binding IsAssigned, Mode=TwoWay}"
                                                  Margin="2"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>

                                                <WrapPanel Grid.Row="2">
                                                    <Button x:Name="SaveStaffResourcesButton"
                                        Content="Sačuvaj resurse"
                                        Width="140"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="SaveStaffResourcesButton_Click"/>
                                                </WrapPanel>
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Raspored i kalendar">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel Margin="8">
                                        <GroupBox Header="Raspored radnika"
                              Margin="0,0,0,10"
                              Padding="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="6"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="6"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <StackPanel Grid.Row="0"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Režim rasporeda"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0"/>
                                                    <ComboBox x:Name="StaffScheduleModeComboBox"
                                          Width="260"
                                          Height="32"
                                          SelectionChanged="StaffScheduleModeComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Fiksno jedno radno vreme" Tag="0"/>
                                                        <ComboBoxItem Content="Smenski rad" Tag="1"/>
                                                        <ComboBoxItem Content="Dvokratno radno vreme" Tag="2"/>
                                                    </ComboBox>
                                                </StackPanel>

                                                <!-- FIKSNO -->
                                                <GroupBox x:Name="FixedSchedulePanel"
                                      Grid.Row="2"
                                      Header="Fiksno radno vreme"
                                      Padding="8">
                                                    <DataGrid x:Name="FixedScheduleGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          MinHeight="190"
                                          MaxHeight="280">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Dan" Width="140" Binding="{Binding DayName}" IsReadOnly="True"/>
                                                            <DataGridCheckBoxColumn Header="Radi" Width="80" Binding="{Binding IsWorkingDay, Mode=TwoWay}"/>
                                                            <DataGridTextColumn Header="Od" Width="90" Binding="{Binding StartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <DataGridTextColumn Header="Do" Width="90" Binding="{Binding EndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </GroupBox>

                                                <!-- SMENSKI -->
                                                <GroupBox x:Name="ShiftSchedulePanel"
                                      Grid.Row="2"
                                      Header="Smenski rad"
                                      Padding="8"
                                      Visibility="Collapsed">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="6"/>
                                                            <RowDefinition Height="*"/>
                                                        </Grid.RowDefinitions>

                                                        <Grid Grid.Row="0" Margin="0,0,0,6">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="8"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <GroupBox Header="Prva smena" Grid.Column="0" Padding="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                        <ColumnDefinition Width="12"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Od"/>
                                                                    <TextBox x:Name="Shift1StartTextBox"
                                                         Grid.Column="1"
                                                         Height="30"
                                                         Margin="6,0,0,0"
                                                         Text="08:00"/>

                                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Do"/>
                                                                    <TextBox x:Name="Shift1EndTextBox"
                                                         Grid.Column="4"
                                                         Height="30"
                                                         Margin="6,0,0,0"
                                                         Text="15:00"/>
                                                                </Grid>
                                                            </GroupBox>

                                                            <GroupBox Header="Druga smena" Grid.Column="2" Padding="8">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                        <ColumnDefinition Width="12"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="90"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Text="Od"/>
                                                                    <TextBox x:Name="Shift2StartTextBox"
                                                         Grid.Column="1"
                                                         Height="30"
                                                         Margin="6,0,0,0"
                                                         Text="11:00"/>

                                                                    <TextBlock Grid.Column="3" VerticalAlignment="Center" Text="Do"/>
                                                                    <TextBox x:Name="Shift2EndTextBox"
                                                         Grid.Column="4"
                                                         Height="30"
                                                         Margin="6,0,0,0"
                                                         Text="17:00"/>
                                                                </Grid>
                                                            </GroupBox>
                                                        </Grid>

                                                        <DataGrid x:Name="ShiftScheduleGrid"
                                              Grid.Row="2"
                                              AutoGenerateColumns="False"
                                              CanUserAddRows="False"
                                              CanUserDeleteRows="False"
                                              SelectionMode="Single"
                                              MinHeight="190"
                                              MaxHeight="280">
                                                            <DataGrid.Columns>
                                                                <DataGridTextColumn Header="Dan" Width="140" Binding="{Binding DayName}" IsReadOnly="True"/>
                                                                <DataGridCheckBoxColumn Header="Radi" Width="80" Binding="{Binding IsWorkingDay, Mode=TwoWay}"/>

                                                                <DataGridTemplateColumn Header="Osnovna smena" Width="150">
                                                                    <DataGridTemplateColumn.CellTemplate>
                                                                        <DataTemplate>
                                                                            <ComboBox SelectedValue="{Binding BaseShift, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  SelectedValuePath="Tag">
                                                                                <ComboBoxItem Content="Prva smena" Tag="1"/>
                                                                                <ComboBoxItem Content="Druga smena" Tag="2"/>
                                                                            </ComboBox>
                                                                        </DataTemplate>
                                                                    </DataGridTemplateColumn.CellTemplate>
                                                                </DataGridTemplateColumn>

                                                                <DataGridCheckBoxColumn Header="Rotira po nedelji"
                                                                    Width="140"
                                                                    Binding="{Binding RotateWeekly, Mode=TwoWay}"/>
                                                            </DataGrid.Columns>
                                                        </DataGrid>
                                                    </Grid>
                                                </GroupBox>

                                                <!-- DVOKRATNO -->
                                                <GroupBox x:Name="SplitSchedulePanel"
                                      Grid.Row="2"
                                      Header="Dvokratno radno vreme"
                                      Padding="8"
                                      Visibility="Collapsed">
                                                    <DataGrid x:Name="SplitScheduleGrid"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          CanUserDeleteRows="False"
                                          SelectionMode="Single"
                                          MinHeight="190"
                                          MaxHeight="280">
                                                        <DataGrid.Columns>
                                                            <DataGridTextColumn Header="Dan" Width="140" Binding="{Binding DayName}" IsReadOnly="True"/>
                                                            <DataGridCheckBoxColumn Header="Radi" Width="80" Binding="{Binding IsWorkingDay, Mode=TwoWay}"/>
                                                            <DataGridTextColumn Header="Prvi deo od" Width="95" Binding="{Binding StartTime1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <DataGridTextColumn Header="Prvi deo do" Width="95" Binding="{Binding EndTime1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <DataGridTextColumn Header="Drugi deo od" Width="100" Binding="{Binding StartTime2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                            <DataGridTextColumn Header="Drugi deo do" Width="100" Binding="{Binding EndTime2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                        </DataGrid.Columns>
                                                    </DataGrid>
                                                </GroupBox>

                                                <WrapPanel Grid.Row="4">
                                                    <Button x:Name="SaveStaffScheduleRulesButton"
                                        Content="Sačuvaj raspored"
                                        Width="150"
                                        Height="32"
                                        Click="SaveStaffScheduleRulesButton_Click"/>
                                                </WrapPanel>
                                            </Grid>
                                        </GroupBox>

                                        <GroupBox Header="Odsustva radnika"
                              Margin="0,0,0,8"
                              Padding="8">
                                            <Grid>
                                                <TabControl x:Name="StaffCalendarTabControl"
                                        SelectionChanged="StaffCalendarTabControl_SelectionChanged">
                                                    <TabItem Header="Slobodni dani">
                                                        <Grid Margin="6">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="6"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>

                                                            <DockPanel Grid.Row="0" LastChildFill="False">
                                                                <Button x:Name="PreviousAbsenceMonthButton"
                                                    Content="&lt;"
                                                    Width="40"
                                                    Height="30"
                                                    Margin="0,0,6,0"
                                                    Click="PreviousAbsenceMonthButton_Click"/>

                                                                <TextBlock x:Name="AbsenceMonthTextBlock"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       Margin="0,0,6,0"
                                                       Text="Mesec"/>

                                                                <Button x:Name="NextAbsenceMonthButton"
                                                    Content="&gt;"
                                                    Width="40"
                                                    Height="30"
                                                    Margin="0,0,10,0"
                                                    Click="NextAbsenceMonthButton_Click"/>

                                                                <Button x:Name="SaveAbsencesButton"
                                                    Content="Sačuvaj odsustva"
                                                    Width="150"
                                                    Height="30"
                                                    Click="SaveAbsencesButton_Click"/>
                                                            </DockPanel>

                                                            <ItemsControl x:Name="AbsenceCalendarItemsControl"
                                                      Grid.Row="2">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="7"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>

                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Content="{Binding DayText}"
                                                            Margin="2"
                                                            Padding="4"
                                                            MinHeight="36"
                                                            Click="AbsenceDayButton_Click"
                                                            Tag="{Binding}">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Background" Value="White"/>
                                                                                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                            <Setter Property="Background" Value="#F2F2F2"/>
                                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                        </DataTrigger>

                                                                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                                            <Setter Property="Opacity" Value="0.45"/>
                                                                                        </DataTrigger>

                                                                                        <DataTrigger Binding="{Binding IsSelectedAbsence}" Value="True">
                                                                                            <Setter Property="Background" Value="#FFD6D6"/>
                                                                                            <Setter Property="BorderBrush" Value="#D66A6A"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </TabItem>

                                                    <TabItem x:Name="ShiftOverrideTabItem" Header="Promena smene">
                                                        <Grid Margin="6">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="6"/>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="6"/>
                                                                <RowDefinition Height="*"/>
                                                            </Grid.RowDefinitions>

                                                            <DockPanel Grid.Row="0" LastChildFill="False">
                                                                <Button x:Name="PreviousShiftOverrideMonthButton"
                                                    Content="&lt;"
                                                    Width="40"
                                                    Height="30"
                                                    Margin="0,0,6,0"
                                                    Click="PreviousAbsenceMonthButton_Click"/>

                                                                <TextBlock x:Name="ShiftOverrideMonthTextBlock"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       FontSize="15"
                                                       Margin="0,0,6,0"
                                                       Text="Mesec"/>

                                                                <Button x:Name="NextShiftOverrideMonthButton"
                                                    Content="&gt;"
                                                    Width="40"
                                                    Height="30"
                                                    Margin="0,0,10,0"
                                                    Click="NextAbsenceMonthButton_Click"/>

                                                                <Button x:Name="SaveShiftOverridesButton"
                                                    Content="Sačuvaj promene smene"
                                                    Width="190"
                                                    Height="30"
                                                    Click="SaveShiftOverridesButton_Click"/>
                                                            </DockPanel>

                                                            <TextBlock Grid.Row="2"
                                                   x:Name="ShiftOverrideInfoTextBlock"
                                                   Text="Klik na datum preokreće smenu za taj dan. Dostupno samo za smenski rad."
                                                   Foreground="#555555"/>

                                                            <ItemsControl x:Name="ShiftOverrideCalendarItemsControl"
                                                      Grid.Row="4">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <UniformGrid Columns="7"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>

                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Button Tag="{Binding}"
                                                            Click="ShiftOverrideDayButton_Click"
                                                            Margin="2"
                                                            Padding="3"
                                                            MinHeight="44">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button">
                                                                                    <Setter Property="Background" Value="White"/>
                                                                                    <Setter Property="BorderBrush" Value="#D0D0D0"/>
                                                                                    <Setter Property="BorderThickness" Value="1"/>
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                                                            <Setter Property="Background" Value="#F2F2F2"/>
                                                                                            <Setter Property="IsHitTestVisible" Value="False"/>
                                                                                        </DataTrigger>

                                                                                        <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                                                                            <Setter Property="Opacity" Value="0.45"/>
                                                                                        </DataTrigger>

                                                                                        <DataTrigger Binding="{Binding IsShiftOverride}" Value="True">
                                                                                            <Setter Property="Background" Value="#DCEEFF"/>
                                                                                            <Setter Property="BorderBrush" Value="#4F8FD9"/>
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>

                                                                            <StackPanel>
                                                                                <TextBlock Text="{Binding DayText}"
                                                                       HorizontalAlignment="Center"/>
                                                                                <TextBlock Text="{Binding ShiftText}"
                                                                       HorizontalAlignment="Center"
                                                                       FontWeight="SemiBold"
                                                                       Margin="0,2,0,0"/>
                                                                            </StackPanel>
                                                                        </Button>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Grid>
                                                    </TabItem>
                                                </TabControl>
                                            </Grid>
                                        </GroupBox>
                                    </StackPanel>
                                </ScrollViewer>
                            </TabItem>
                        </TabControl>
                    </GroupBox>
                </Grid>

                <Grid x:Name="ResourcesSection" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Grid.Column="0" Header="Resursi" Padding="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0" LastChildFill="False">
                                <Button x:Name="RefreshResourcesButton"
                                        Content="Osveži"
                                        Width="100"
                                        Height="32"
                                        Margin="0,0,8,0"
                                        Click="RefreshResourcesButton_Click"/>
                                <Button x:Name="NewResourceButton"
                                        Content="Novi resurs"
                                        Width="120"
                                        Height="32"
                                        Click="NewResourceButton_Click"/>
                            </DockPanel>

                            <DataGrid Grid.Row="2"
                                      x:Name="ResourcesGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionMode="Single"
                                      SelectionChanged="ResourcesGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Naziv" Width="220" Binding="{Binding Name}" />
                                    <DataGridCheckBoxColumn Header="Aktivan" Width="90" Binding="{Binding IsActive}" />
                                    <DataGridTextColumn Header="Opis" Width="*" Binding="{Binding Description}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="2" Header="Detalji resursa" Padding="10">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Naziv resursa"/>
                                <TextBox x:Name="ResourceNameTextBox" Height="34" Margin="0,6,0,12"/>

                                <TextBlock Text="Opis"/>
                                <TextBox x:Name="ResourceDescriptionTextBox"
         Height="100"
         Margin="0,6,0,12"
         TextWrapping="Wrap"
         AcceptsReturn="True"/>

                                <CheckBox x:Name="ResourceCreatesOccupancyCheckBox"
          Content="Ovaj resurs pravi zauzeće"
          Margin="0,0,0,8"
          IsChecked="True"/>

                                <TextBlock Margin="0,0,0,12"
           Foreground="#666666"
           TextWrapping="Wrap">
    Ako je uključeno, resurs ulazi u proveru zauzeća i može blokirati druge termine.
    Ako nije uključeno, resurs je informativan i ne pravi konflikt zauzeća.
                                </TextBlock>

                                <CheckBox x:Name="ResourceIsActiveCheckBox"
          Content="Resurs je aktivan"
          Margin="0,0,0,12"
          IsChecked="True"/>

                                <WrapPanel Margin="0,0,0,12">
                                    <Button x:Name="SaveNewResourceButton"
                                            Content="Sačuvaj novi"
                                            Width="130"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Click="SaveNewResourceButton_Click"/>
                                    <Button x:Name="SaveResourceChangesButton"
                                            Content="Sačuvaj izmene"
                                            Width="130"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Click="SaveResourceChangesButton_Click"/>
                                    <Button x:Name="ActivateResourceButton"
                                            Content="Aktiviraj"
                                            Width="110"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Click="ActivateResourceButton_Click"/>
                                    <Button x:Name="DeactivateResourceButton"
                                            Content="Deaktiviraj"
                                            Width="110"
                                            Height="36"
                                            Margin="0,0,8,8"
                                            Click="DeactivateResourceButton_Click"/>
                                    <Button x:Name="DeleteResourceButton"
        Content="Obriši"
        Width="110"
        Height="36"
        Margin="0,0,8,8"
        Click="DeleteResourceButton_Click"/>
                                </WrapPanel>

                                <Border Padding="10"
                                        Background="#F7F7F7"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock TextWrapping="Wrap"
           Foreground="#555555">
    Ovdje podešavate osnovne podatke o resursu i da li taj resurs pravi stvarno zauzeće.
    Resurs „Čekanje” se koristi kao poseban sistemski resurs koji ne pravi konflikt zauzeća.
    Kasnije možemo dodati i tip resursa, kapacitet i naprednija pravila ponašanja.
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </GroupBox>
                </Grid>

                <Grid x:Name="WorkingHoursSection" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <Button x:Name="RefreshWorkingHoursButton"
                                Content="Osveži"
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="RefreshWorkingHoursButton_Click"/>
                        <Button x:Name="SaveWorkingHoursButton"
                                Content="Sačuvaj radno vreme"
                                Width="170"
                                Height="32"
                                Click="SaveWorkingHoursButton_Click"/>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.3*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Radno vreme biznisa" Padding="8">
                            <DataGrid x:Name="WorkingHoursGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      SelectionMode="Single">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Dan" Width="180" Binding="{Binding DayName}" IsReadOnly="True"/>
                                    <DataGridCheckBoxColumn Header="Radi" Width="90" Binding="{Binding IsWorkingDay}"/>
                                    <DataGridTextColumn Header="Od" Width="100" Binding="{Binding StartTime}"/>
                                    <DataGridTextColumn Header="Do" Width="100" Binding="{Binding EndTime}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Napomena" Padding="10">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                                    Ovde podešavate osnovno radno vreme biznisa po danima u nedelji.
                                </TextBlock>

                                <Border Padding="10"
                                        Background="#F7F7F7"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#555555">
                                        TODO: Kasnije dodati pauze u toku dana.
                                        TODO: Kasnije dodati radno vreme po radniku.
                                        TODO: Kasnije dodati posebne datume, praznike i odsustva.
                                        TODO: Kasnije dodati više smena po danu ako zatreba.
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </Grid>

                <Grid x:Name="BusinessSection" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False">
                        <Button x:Name="RefreshBusinessButton"
                                Content="Osveži"
                                Width="100"
                                Height="32"
                                Margin="0,0,8,0"
                                Click="RefreshBusinessButton_Click"/>
                        <Button x:Name="SaveBusinessButton"
                                Content="Sačuvaj podatke"
                                Width="150"
                                Height="32"
                                Click="SaveBusinessButton_Click"/>
                    </DockPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="1.4*"/>
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0" Header="Podaci o biznisu" Padding="10">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Naziv biznisa"/>
                                        <TextBox x:Name="BusinessNameTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Tip biznisa"/>
                                        <ComboBox x:Name="BusinessTypeComboBox"
                                                  Height="34"
                                                  Margin="0,6,0,12">
                                            <ComboBoxItem Content="Salon" Tag="0"/>
                                            <ComboBoxItem Content="Ordinacija" Tag="1"/>
                                            <ComboBoxItem Content="Servis" Tag="2"/>
                                            <ComboBoxItem Content="Restoran" Tag="3"/>
                                            <ComboBoxItem Content="Drugo" Tag="99"/>
                                        </ComboBox>

                                        <TextBlock Text="Telefon"/>
                                        <TextBox x:Name="BusinessPhoneTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Email"/>
                                        <TextBox x:Name="BusinessEmailTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Dužina osnovnog termina (min)"/>
                                        <TextBox x:Name="BusinessSlotIntervalTextBox" Height="34" Margin="0,6,0,4"/>

                                        <TextBlock Margin="0,0,0,12"
           Foreground="#666666"
           TextWrapping="Wrap">
    Ovo je osnovni korak zakazivanja, na primer 30 minuta.
    Sistem može kasnije ponuditi i kraće slobodne rupe ako usluga stvarno staje u taj period.
                                        </TextBlock>

                                        <CheckBox x:Name="BusinessIsActiveCheckBox"
                                                  Content="Biznis je aktivan"
                                                  Margin="0,0,0,12"
                                                  IsChecked="True"/>

                                        <TextBlock Text="Opis"/>
                                        <TextBox x:Name="BusinessDescriptionTextBox"
                                                 Height="100"
                                                 Margin="0,6,0,12"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Ulica"/>
                                        <TextBox x:Name="BusinessStreetTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Broj"/>
                                        <TextBox x:Name="BusinessStreetNumberTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Grad"/>
                                        <TextBox x:Name="BusinessCityTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Poštanski broj"/>
                                        <TextBox x:Name="BusinessPostalCodeTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Država"/>
                                        <TextBox x:Name="BusinessCountryTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Latitude"/>
                                        <TextBox x:Name="BusinessLatitudeTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Longitude"/>
                                        <TextBox x:Name="BusinessLongitudeTextBox" Height="34" Margin="0,6,0,12"/>

                                        <TextBlock Text="Google Place ID"/>
                                        <TextBox x:Name="BusinessGooglePlaceIdTextBox" Height="34" Margin="0,6,0,12"/>
                                    </StackPanel>
                                </Grid>
                            </ScrollViewer>
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="Napomena" Padding="10">
                            <StackPanel>
                                <TextBlock TextWrapping="Wrap" Margin="0,0,0,12">
                                    Ovde menjate osnovne podatke o svom biznisu, adresu i kontakt informacije.
                                </TextBlock>

                                <Border Padding="10"
                                        Background="#F7F7F7"
                                        BorderBrush="#DDDDDD"
                                        BorderThickness="1"
                                        CornerRadius="6">
                                    <TextBlock TextWrapping="Wrap"
                                               Foreground="#555555">
                                        TODO: Kasnije dodati automatsko povezivanje sa mapom i izbor lokacije.
                                        TODO: Kasnije dodati otvaranje lokacije u Google Maps.
                                        TODO: Kasnije dodati validaciju email-a, telefona i adrese po polju.
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                    </Grid>
                </Grid>

                <Grid x:Name="PlaceholderSection" Visibility="Collapsed">
                    <Border Background="#FAFAFA"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="20">
                        <TextBlock x:Name="PlaceholderTextBlock"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Ova sekcija će biti dodata uskoro."/>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>