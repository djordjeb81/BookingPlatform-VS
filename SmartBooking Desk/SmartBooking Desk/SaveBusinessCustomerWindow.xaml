<Window x:Class="SmartBooking_Desk.SaveBusinessCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Zapamti klijenta"
        Height="500"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#FFF7F7F7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="0,0,0,14"
                BorderBrush="#22000000"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="Zapamti klijenta"
                           FontSize="22"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Proverite podatke pre čuvanja u bazu klijenata."
                           Margin="0,6,0,0"
                           Foreground="#666"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,16">

            <TextBlock Text="Ime i prezime"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="TextBoxFullName"
                     Margin="0,6,0,14"
                     Height="34"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Telefon"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="TextBoxPhone"
                     Margin="0,6,0,14"
                     Height="34"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Email"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="TextBoxEmail"
                     Margin="0,6,0,14"
                     Height="34"
                     VerticalContentAlignment="Center"/>

            <TextBlock Text="Napomena"
                       FontWeight="SemiBold"/>
            <TextBox x:Name="TextBoxNotes"
                     Margin="0,6,0,14"
                     Height="110"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>

            <Border Background="#FFF3F6FA"
                    BorderBrush="#FFD7E3F4"
                    BorderThickness="1"
                    Padding="10"
                    CornerRadius="8">
                <TextBlock x:Name="TextBlockStatus"
                           Text="Ovaj klijent će biti dodat u bazu klijenata izabranog biznisa."
                           Foreground="#335"
                           TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="ButtonCancel"
                    Grid.Column="1"
                    Content="Odustani"
                    Width="105"
                    Height="36"
                    Margin="0,0,10,0"
                    Click="ButtonCancel_Click"/>

            <Button x:Name="ButtonSave"
                    Grid.Column="2"
                    Content="Sačuvaj"
                    Width="120"
                    Height="36"
                    Click="ButtonSave_Click"/>
        </Grid>
    </Grid>
</Window>