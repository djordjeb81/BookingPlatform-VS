<Window x:Class="SmartBooking_Desk.ProposeAppointmentTimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Predloži novi termin"
        Height="420"
        Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Predlog novog termina"
                   FontSize="20"
                   FontWeight="SemiBold"/>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Datum"/>
            <DatePicker x:Name="DatePickerAppointmentDate"
                        Margin="0,6,0,0"
                        SelectedDateChanged="AppointmentInputs_Changed"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="Slobodan termin"/>
            <ComboBox x:Name="ComboBoxAvailableSlots"
                      Margin="0,6,0,0"
                      Height="34"
                      DisplayMemberPath="DisplayText"
                      DropDownOpened="ComboBoxAvailableSlots_DropDownOpened"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Poruka"/>
            <TextBox x:Name="TextBoxMessage"
                     Margin="0,6,0,0"
                     Height="80"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <TextBlock x:Name="TextBlockStatus"
                   Grid.Row="8"
                   Text="Izaberite datum i termin."
                   TextWrapping="Wrap"
                   Foreground="#555555"/>

        <StackPanel Grid.Row="10"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ButtonCancel"
                    Content="Odustani"
                    Width="110"
                    Height="34"
                    Margin="0,0,8,0"
                    Click="ButtonCancel_Click"/>
            <Button x:Name="ButtonSave"
                    Content="Pošalji predlog"
                    Width="140"
                    Height="34"
                    Click="ButtonSave_Click"/>
        </StackPanel>
    </Grid>
</Window>